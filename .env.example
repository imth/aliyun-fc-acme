# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 域名分组配置（JSON 格式）
# name: 证书标识名称
# domains: 域名列表，第一个作为 CN，支持通配符
# deploy: 续期后是否自动部署到引用了旧证书的云产品（默认 true）
CERT_CONFIGS='[{"name": "example.com", "domains": ["example.com", "*.example.com"]}]'

# 阿里云凭证（可选）
# FC 线上运行时通过服务角色自动获取凭证，无需配置
# 本地开发时需要设置 AK/SK
# ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret

# ACME 账户邮箱（可选，用于 Let's Encrypt 证书过期提醒）
# ACME_EMAIL=admin@example.com

# 是否使用 Let's Encrypt staging 环境（默认 false）
# 开发测试时可设为 true，避免触发 LE 速率限制
# ACME_STAGING=true

# 证书到期前多少天触发续期（默认 30，范围 1-60）
RENEW_DAYS=30

# 证书获取后自动部署到哪些服务（逗号分隔，目前支持: oss）
# 为空或不设置则仅上传到 CAS
DEPLOY_TO=oss
